# Local .terraform directory (contains providers and modules)
.terraform/

# .tfstate files (contains sensitive infra data and should be in remote backends)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all variable files as they often contain secrets
*.tfvars
*.tfvars.json

# Ignore override files as they are typically for local testing
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override example for documentation (optional)
!example_override.tf

# Ignore transient lock files
.terraform.tfstate.lock.info

# Ignore plan output files
*.tfplan
